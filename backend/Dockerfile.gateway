FROM maven:3.9-eclipse-temurin-17-alpine AS builder

WORKDIR /build

COPY pom.xml ./
COPY shared shared/
COPY services services/

RUN mvn -B -DskipTests -pl services/api-gateway -am package

FROM eclipse-temurin:17-jre-alpine

RUN addgroup -S spring \
    && adduser -S spring -G spring \
    && apk add --no-cache wget \
    && mkdir -p /var/log/app /app \
    && chown -R spring:spring /var/log/app /app

WORKDIR /app

COPY --from=builder /build/services/api-gateway/target/*.jar app.jar

ENV JAVA_OPTS="-Xms128m -Xmx256m -XX:+UseG1GC -XX:MaxGCPauseMillis=200"

HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=60s \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8082/actuator/health || exit 1

USER spring:spring
EXPOSE 8082

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
